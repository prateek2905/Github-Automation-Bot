generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  githubId      BigInt         @unique
  login         String
  name          String?
  avatarUrl     String?
  createdAt     DateTime       @default(now())
  installations Installation[]
  repos         Repo[]
  rules         Rule[]
}

model Installation {
  id                   String   @id @default(cuid())
  githubInstallationId BigInt   @unique
  accountLogin         String
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())
  repos                Repo[]
}

model Repo {
  id             String       @id @default(cuid())
  githubRepoId   BigInt       @unique
  fullName       String
  active         Boolean      @default(true)
  installationId String
  installation   Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  rules          Rule[]
}

model Rule {
  id          String   @id @default(cuid())
  name        String
  eventType   String
  matchField  String
  matchType   String
  matchValue  String
  addLabel    Boolean  @default(false)
  labelName   String?
  comment     Boolean  @default(false)
  commentBody String?
  slackNotify Boolean  @default(true)
  enabled     Boolean  @default(true)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  repoId      String?
  repo        Repo?    @relation(fields: [repoId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Event {
  id             String      @id @default(cuid())
  deliveryId     String      @unique
  installationId BigInt?
  repoFullName   String?
  eventType      String
  action         String?
  senderLogin    String?
  title          String?
  payload        Json
  status         String      @default("received")
  attempts       Int         @default(0)
  lastError      String?
  nextAttemptAt  DateTime    @default(now())
  receivedAt     DateTime    @default(now())
  processedAt    DateTime?
  actions        ActionLog[]

  @@index([status, nextAttemptAt])
}

model ActionLog {
  id             String   @id @default(cuid())
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ruleId         String?
  repoFullName   String?
  actionType     String
  status         String
  detail         String?
  idempotencyKey String   @unique
  createdAt      DateTime @default(now())

  @@index([createdAt])
}
