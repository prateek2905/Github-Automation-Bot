# Postgres connection string (Neon pooled connection recommended)
DATABASE_URL=

# Public URL of this backend once deployed (used to build OAuth/webhook callback URLs)
APP_URL=http://localhost:3000

# Public URL of the deployed frontend (used to redirect after OAuth login)
FRONTEND_URL=http://localhost:5173

# Secret used to sign our own session JWTs (any long random string)
JWT_SECRET=

# GitHub App settings (from https://github.com/settings/apps/<your-app>)
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=
# Base64-encoded contents of the .pem private key downloaded from the App settings page
GITHUB_APP_PRIVATE_KEY_BASE64=

# Slack Incoming Webhook URL
SLACK_WEBHOOK_URL=
